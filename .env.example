# LLM access via haex-claude-proxy (Anthropic-compatible)
ANTHROPIC_BASE_URL=http://localhost:8080
ANTHROPIC_API_KEY=proxy-not-used-but-sdk-requires-it

# Web research
TAVILY_API_KEY=

# fwbg API
FWBG_API_URL=http://localhost:8420
# Sent as X-API-Key on every fwbg request. Must match the fwbg server's
# FWBG_API_KEY. Leave empty only if the server runs with
# FWBG_ALLOW_UNAUTHENTICATED_API=1 (local dev).
FWBG_API_KEY=
# The paired fwbg server should run with FWBG_MAX_CONCURRENT_RUNS=1 unless
# deliberately tuned: the runner expects 429 when the single slot is busy and
# waits for it rather than burning a universe attempt.

# IG broker (only needed once M6/M7 land)
IG_DEMO_USERNAME=
IG_DEMO_PASSWORD=
IG_DEMO_API_KEY=
IG_LIVE_USERNAME=
IG_LIVE_PASSWORD=
IG_LIVE_API_KEY=

# GitHub PAT for PromoteAgent (only needed once M8 lands)
GITHUB_TOKEN=

# Service
API_PORT=8421
LOG_LEVEL=INFO
